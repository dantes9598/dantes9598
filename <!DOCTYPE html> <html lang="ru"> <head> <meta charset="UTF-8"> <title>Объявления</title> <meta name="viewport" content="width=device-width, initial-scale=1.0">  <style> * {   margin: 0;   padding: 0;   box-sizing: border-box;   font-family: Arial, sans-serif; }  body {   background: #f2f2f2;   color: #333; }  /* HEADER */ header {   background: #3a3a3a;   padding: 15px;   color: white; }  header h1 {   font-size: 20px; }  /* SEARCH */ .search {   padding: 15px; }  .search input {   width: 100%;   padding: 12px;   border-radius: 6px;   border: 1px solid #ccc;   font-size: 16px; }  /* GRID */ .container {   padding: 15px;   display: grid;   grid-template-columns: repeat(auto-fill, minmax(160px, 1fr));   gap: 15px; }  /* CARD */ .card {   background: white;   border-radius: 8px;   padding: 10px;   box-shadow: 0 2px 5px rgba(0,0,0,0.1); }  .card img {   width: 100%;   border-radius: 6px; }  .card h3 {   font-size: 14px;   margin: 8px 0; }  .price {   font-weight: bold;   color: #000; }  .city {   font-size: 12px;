<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<title>Объявления</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Arial, sans-serif;
}

body {
  background: #f2f2f2;
  color: #333;
}

/* HEADER */
header {
  background: #3a3a3a;
  padding: 15px;
  color: white;
}

header h1 {
  font-size: 20px;
}

/* SEARCH */
.search {
  padding: 15px;
}

.search input {
  width: 100%;
  padding: 12px;
  border-radius: 6px;
  border: 1px solid #ccc;
  font-size: 16px;
}

/* GRID */
.container {
  padding: 15px;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 15px;
}

/* CARD */
.card {
  background: white;
  border-radius: 8px;
  padding: 10px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.card img {
  width: 100%;
  border-radius: 6px;
}

.card h3 {
  font-size: 14px;
  margin: 8px 0;
}

.price {
  font-weight: bold;
  color: #000;
}

.city {
  font-size: 12px;
  color: #777;
}

/* BUTTON */
.add {
  position: fixed;
  bottom: 20px;
  right: 20px;
  background: #4a4a4a;
  color: white;
  border: none;
  border-radius: 50%;
  width: 55px;
  height: 55px;
  font-size: 28px;
  cursor: pointer;
}
</style>
</head>

<body>

<header>
  <h1>Доска объявлений</h1>
</header>

<div class="search">
  <input type="text" placeholder="Поиск объявлений...">
</div>

<div class="container">
  <div class="card">
    <img src="https://via.placeholder.com/300x200">
    <h3>iPhone 12, отличное состояние</h3>
    <div class="price">12 000 грн</div>
    <div class="city">Киев</div>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/300x200">
    <h3>Samsung Galaxy S21</h3>
    <div class="price">10 500 грн</div>
    <div class="city">Львов</div>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/300x200">
    <h3>Ноутбук Lenovo</h3>
    <div class="price">8 300 грн</div>
    <div class="city">Одесса</div>
  </div>
</div>

<button class="add">+</button>

</body>
</html>